# ─── Neo4j Aura ──────────────────────────────────────────────────────────────────
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_generated_password
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=xxxxxxxx
AURA_INSTANCENAME=Free instance

# ─── Cloudflare Workers AI ───────────────────────────────────────────────────────
# Get from: https://dash.cloudflare.com → Workers & Pages → Workers AI
CF_ACCOUNT_ID=your_cf_account_id
CF_API_TOKEN=your_cf_api_token

# ─── LLM Model (Cloudflare) ──────────────────────────────────────────────────────
# Default: @cf/meta/llama-3.3-70b-instruct-fp8-fast
# Options: @cf/mistral/mistral-7b-instruct-v0.1
#          @cf/google/gemma-7b-it
CF_LLM_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# ─── Embedding Model (Cloudflare) ────────────────────────────────────────────────
# Default: @cf/baai/bge-large-en-v1.5 → 1024 dimensions
CF_EMBED_MODEL=@cf/baai/bge-large-en-v1.5

# ─── Optional: OpenAI (fallback for embeddings if CF fails) ──────────────────────
# OPENAI_API_KEY=sk-...

# ─── Optional: Anthropic (higher quality generation) ─────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Redis (query result cache) ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── AWS S3 (original PDF storage — optional) ────────────────────────────────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=docqa-pdfs
# AWS_REGION=us-east-1

# ─── OCR Backend ─────────────────────────────────────────────────────────────────
# Options: "tesseract" (local, free) | "textract" (AWS, accurate)
OCR_BACKEND=tesseract

# OCR.space API Key (Free registration at https://ocr.space/ocrapi)
# Default test key is 'helloworld'
OCR_SPACE_API_KEY=helloworld

# Frontend (Vite)
# These are safe to expose in the browser. Vite only exposes variables prefixed with VITE_.
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_WS_BASE_URL=ws://localhost:8000/api/v1
VITE_TENANT_ID=tenant-123
