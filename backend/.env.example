# ─────────────────────────────────────────────────────────────────────────────
# DocsAI — Environment Variables Template
# Copy this to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Neo4j Aura (Graph Database) ───────────────────────────────────────────────
# Get from: https://console.neo4j.io  → your Aura instance
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ── Cloudflare Workers AI ─────────────────────────────────────────────────────
# Get from: https://dash.cloudflare.com → AI → API Tokens
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token

# ── Redis Cache ───────────────────────────────────────────────────────────────
# Local: redis://localhost:6379  |  Cloud: Upstash, Redis Cloud, etc.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_SECONDS=3600

# ── Optional: OpenAI (embedding fallback) ─────────────────────────────────────
# Only needed if Cloudflare BGE is unavailable
OPENAI_API_KEY=sk-...

# ── Optional: Anthropic (LLM fallback) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional: AWS Textract (enterprise OCR) ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── App Settings ──────────────────────────────────────────────────────────────
APP_ENV=development               # development | production
LOG_LEVEL=INFO
